# Server Configuration
PORT=3200
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# WhatsApp Cloud API Configuration
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_WABA_ID=your-whatsapp-business-account-id
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/whatsapp-webhook

# SMS Gateway Configuration
SMS_GATEWAY_URL=http://localhost:8080
SMS_GATEWAY_API_KEY=your-sms-gateway-api-key
SMS_GATEWAY_TIMEOUT=10000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Bulk Messenger
SMTP_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 Configuration (Optional - for media storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/3gpp

# Subscription Configuration
DEFAULT_TRIAL_DAYS=14
GRACE_PERIOD_DAYS=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
